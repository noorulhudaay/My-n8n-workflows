    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a 10-second video scene for the following idea:\n\n{{ $json.Idea }}\n\nMake it scroll-stopping, visually concrete, and emotionally immediate.",
        "messages": {
          "messageValues": [
            {
              "message": "You are a creative video scriptwriter specializing in short-form content. Your job is to write a single punchy scene for a 10-second video.\n\nYour output must follow this exact structure:\n\n**SCENE:**\n[One vivid, specific visual description of what's on screen. Max 2 sentences.]\n\n**VOICEOVER / TEXT ON SCREEN:**\n[The spoken line or text overlay. Must be under 20 words — readable in 10 seconds.]\n\n**MOOD & STYLE:**\n[One line: tone, color palette, and pacing. E.g. \"Dark, high-contrast, fast cuts.\"]\n\n**HOOK:**\n[Why this grabs attention in the first 2 seconds.]\n\nKeep it punchy. No fluff. Every word earns its place."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
